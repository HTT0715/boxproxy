#!/system/bin/sh

scripts_dir="${0%/*}"
box_dir="/data/adb/box"
run_dir="${box_dir}/run"
bin_file="${box_dir}/bin/sing-box"
config_file="${box_dir}/sing-box/config.json"
pid_file="${run_dir}/box.pid"
log_file="${run_dir}/sing-box.log"

# ====== 参数 ======
max_retry=5
check_timeout=10

# 仅 start boot 使用
boot_max_wait=180
boot_check_interval=10

# 路由错误检测
route_error_check_time=8

# ====== 防火墙配置 ======
LAN="192.168.0.0/24"
TUN="utun"

mkdir -p "$run_dir"

log() {
    echo "[boxproxy] $1"
}

is_running() {
    [ -f "$pid_file" ] || return 1
    pid="$(cat "$pid_file" 2>/dev/null)"
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null
}

has_default_route() {
    ip route 2>/dev/null | grep -q '^default '
}

wait_boot_network() {
    waited=0
    log "开机模式：等待默认路由出现，最多 ${boot_max_wait}s"

    while [ "$waited" -lt "$boot_max_wait" ]; do
        if has_default_route; then
            log "检测到默认路由，继续启动"
            return 0
        fi

        log "暂无默认路由，等待 ${boot_check_interval}s..."
        sleep "$boot_check_interval"
        waited=$((waited + boot_check_interval))
    done

    log "等待默认路由超时，继续启动并交给重试逻辑"
    return 1
}

detect_tun() {
    if [ ! -d "/sys/class/net/$TUN" ]; then
        TUN="$(ip -o link 2>/dev/null | awk -F': ' '/tun|utun|clash|mihomo/{print $2; exit}')"
    fi
    [ -z "$TUN" ] && TUN="utun"
}

add_rule() {
    iptables -C "$@" 2>/dev/null || iptables -I "$@"
}

del_rule() {
    while iptables -D "$@" 2>/dev/null; do :; done
}

fw_add() {
    detect_tun
    log "添加防火墙规则 LAN=$LAN TUN=$TUN"

    add_rule FORWARD -s "$LAN" -o "$TUN" -j ACCEPT
    add_rule FORWARD -i "$TUN" -d "$LAN" -j ACCEPT
    add_rule FORWARD -i "$TUN" -j ACCEPT
    add_rule FORWARD -o "$TUN" -j ACCEPT
    add_rule OUTPUT -o "$TUN" -j ACCEPT

    echo "防火墙规则已添加"
}

fw_del() {
    detect_tun
    log "清理防火墙规则 LAN=$LAN TUN=$TUN"

    del_rule FORWARD -s "$LAN" -o "$TUN" -j ACCEPT
    del_rule FORWARD -i "$TUN" -d "$LAN" -j ACCEPT
    del_rule FORWARD -i "$TUN" -j ACCEPT
    del_rule FORWARD -o "$TUN" -j ACCEPT
    del_rule OUTPUT -o "$TUN" -j ACCEPT

    echo "防火墙规则已清理"
}

has_route_error() {
    tail -n 120 "$log_file" 2>/dev/null | grep -Ei \
        'no route|no default route|network is unreachable|network unreachable|ENETUNREACH|connect: network|route.*not found|no such network' \
        >/dev/null
}

stop_core() {
    if is_running; then
        pid="$(cat "$pid_file" 2>/dev/null)"
        log "停止 sing-box PID=$pid"
        kill "$pid" 2>/dev/null
        sleep 2
        kill -9 "$pid" 2>/dev/null
    fi

    pkill -f "sing-box run" 2>/dev/null
    pkill -f "$bin_file" 2>/dev/null
    rm -f "$pid_file"
}

start_core() {
    if [ ! -x "$bin_file" ]; then
        echo "错误：找不到核心或不可执行：$bin_file"
        return 1
    fi

    if [ ! -f "$config_file" ]; then
        echo "错误：找不到配置文件：$config_file"
        return 1
    fi

    echo "" > "$log_file"

    nohup "$bin_file" run -c "$config_file" > "$log_file" 2>&1 &
    echo "$!" > "$pid_file"
}

check_core() {
    i=0

    while [ "$i" -lt "$check_timeout" ]; do
        if is_running; then
            break
        fi

        sleep 1
        i=$((i + 1))
    done

    if ! is_running; then
        log "核心进程未存活"
        return 1
    fi

    i=0
    while [ "$i" -lt "$route_error_check_time" ]; do
        if has_route_error; then
            log "检测到路由错误日志"
            tail -n 40 "$log_file" 2>/dev/null
            return 2
        fi

        sleep 1
        i=$((i + 1))
    done

    return 0
}

start_with_retry() {
    retry=1

    while [ "$retry" -le "$max_retry" ]; do
        log "启动 sing-box，尝试 ${retry}/${max_retry}"

        stop_core
        sleep 1
        start_core

        check_core
        ret="$?"

        if [ "$ret" = "0" ]; then
            pid="$(cat "$pid_file" 2>/dev/null)"
            log "sing-box 启动成功 PID=$pid"
            return 0
        fi

        if [ "$ret" = "2" ]; then
            log "发现 no route / no default route / network unreachable，准备重启核心"
        else
            log "启动失败或检测超时，准备重试"
        fi

        stop_core
        sleep 3
        retry=$((retry + 1))
    done

    log "启动失败，已达最大重试次数"
    return 1
}

case "$1" in

start)
    log "启动 boxproxy"

    if [ "$2" = "boot" ]; then
        wait_boot_network
    fi

    fw_add

    if start_with_retry; then
        exit 0
    else
        fw_del
        exit 1
    fi
;;

stop)
    log "停止 boxproxy"
    stop_core
    fw_del
    log "已停止"
;;

restart)
    log "重启 boxproxy"
    stop_core
    fw_del
    sleep 1
    fw_add

    if start_with_retry; then
        exit 0
    else
        fw_del
        exit 1
    fi
;;

status)
    echo "=== BoxProxy 状态 ==="
    echo "目录: $box_dir"
    echo "核心: $bin_file"
    echo "配置: $config_file"
    echo "PID文件: $pid_file"
    echo "日志: $log_file"
    echo "LAN: $LAN"
    echo "TUN: $TUN"
    echo ""

    if is_running; then
        echo "状态: 运行中"
        echo "PID: $(cat "$pid_file" 2>/dev/null)"
        ps -ef 2>/dev/null | grep -E 'sing-box|mihomo|xray|box' | grep -v grep
    else
        echo "状态: 未运行"
    fi

    echo ""
    echo "=== 默认路由 ==="
    ip route 2>/dev/null | grep '^default ' || echo "无默认路由"

    echo ""
    echo "=== TUN 网卡 ==="
    detect_tun
    ip addr show "$TUN" 2>/dev/null || echo "未发现 TUN: $TUN"

    echo ""
    echo "=== 防火墙规则 ==="
    iptables -S FORWARD 2>/dev/null | grep -E "$TUN|tun|utun|mihomo|clash" || true
    iptables -S OUTPUT 2>/dev/null | grep -E "$TUN|tun|utun|mihomo|clash" || true

    echo ""
    echo "=== 最近日志 ==="
    tail -n 80 "$log_file" 2>/dev/null || echo "暂无日志"
;;

fw-add)
    fw_add
;;

fw-del)
    fw_del
;;

*)
    echo "用法: $0 {start|stop|restart|status|fw-add|fw-del}"
    exit 1
;;

esac